// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                     Int       @id @default(autoincrement())
  nombre                 String?
  nombreArtistico        String?   @map("nombre_artistico")
  nombreUsuario          String?   @unique @map("nombre_usuario")
  fotoPerfil             String?   @map("foto_perfil") @db.VarChar(500)
  biografia              String?   @db.VarChar(300)
  spotifyUrl             String?   @map("spotify_url") @db.VarChar(500)
  youtubeUrl             String?   @map("youtube_url") @db.VarChar(500)
  instagramUrl           String?   @map("instagram_url") @db.VarChar(500)
  distribuidoraPreferida String?   @map("distribuidora_preferida") @db.VarChar(120)
  softwarePreferido      String?   @map("software_preferido") @db.VarChar(120)
  correo                 String    @unique
  passwordHash           String    @map("password_hash")
  pais                   String?
  ciudad                 String?
  idiomaPrincipal        String?   @map("idioma_principal")
  rolPrincipal           String    @map("rol_principal")
  generos                Json?
  tipoColaboracion       String?   @map("tipo_colaboracion")
  correoVerificado       Boolean   @default(true) @map("correo_verificado")
  perfilCompleto         Boolean   @default(false) @map("perfil_completo")
  aceptoTerminosEn       DateTime? @map("acepto_terminos_en")
  creadoEn               DateTime  @default(now()) @map("creado_en")
  actualizadoEn          DateTime  @updatedAt @map("actualizado_en")

  ideas Idea[]

  @@map("usuarios")
}


model Idea {
  id               Int      @id @default(autoincrement())
  usuarioId        Int      @map("usuario_id")
  titulo           String   @db.VarChar(80)
  descripcion      String   @db.VarChar(300)
  bpm              Int
  tonalidad        String   @db.VarChar(30)
  audioUrl         String   @map("audio_url") @db.VarChar(1000)
  audioPublicId    String   @map("audio_public_id") @db.VarChar(255)
  duracionSegundos Int      @map("duracion_segundos")
  formato          String?  @db.VarChar(20)
  tamanoBytes      Int?     @map("tamano_bytes")
  estado           String   @default("ACTIVA") @db.VarChar(20)
  expiraEn         DateTime @map("expira_en")
  creadoEn         DateTime @default(now()) @map("creado_en")
  actualizadoEn    DateTime @updatedAt @map("actualizado_en")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, estado, expiraEn])
  @@map("ideas")
}

model RegistroPendiente {
  id               Int      @id @default(autoincrement())
  correo           String   @unique
  passwordHash     String   @map("password_hash")
  rolPrincipal     String   @map("rol_principal")
  codigoHash       String   @map("codigo_hash")
  codigoExpiraEn   DateTime @map("codigo_expira_en")
  intentosCodigo   Int      @default(0) @map("intentos_codigo")
  ultimoEnvioEn    DateTime @default(now()) @map("ultimo_envio_en")
  aceptoTerminosEn DateTime @map("acepto_terminos_en")
  creadoEn         DateTime @default(now()) @map("creado_en")
  actualizadoEn    DateTime @updatedAt @map("actualizado_en")

  @@map("registros_pendientes")
}

model RecuperacionPassword {
  id             Int      @id @default(autoincrement())
  correo         String   @unique
  codigoHash     String   @map("codigo_hash")
  codigoExpiraEn DateTime @map("codigo_expira_en")
  intentosCodigo Int      @default(0) @map("intentos_codigo")
  ultimoEnvioEn  DateTime @default(now()) @map("ultimo_envio_en")
  creadoEn       DateTime @default(now()) @map("creado_en")
  actualizadoEn  DateTime @updatedAt @map("actualizado_en")

  @@map("recuperaciones_password")
}
